{
  "name": "@dotagents/ldi",
  "version": "0.0.1",
  "description": "Live Desktop Integrator — render any URL as a desktop background layer",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "src",
    "scripts"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ldi",
    "desktop",
    "background",
    "dotagents",
    "cross-platform",
    "x11",
    "linux"
  ],
  "private": true
}
