{
  "name": "dotagents-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "DotAgents — Your AI team. One voice away. Voice-first agent orchestrator built on the .agents open standard.",
  "scripts": {
    "dev": "pnpm --filter @dotagents/desktop dev",
    "dev:mobile": "pnpm --filter @dotagents/mobile start",
    "build": "pnpm --filter @dotagents/shared build && pnpm --filter @dotagents/core build && pnpm --filter @dotagents/desktop build",
    "build:shared": "pnpm --filter @dotagents/shared build",
    "build:core": "pnpm --filter @dotagents/core build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "docs:coverage": "node scripts/check-docs-coverage.mjs"
  },
  "engines": {
    "node": ">=20.19.4",
    "pnpm": "9.x"
  },
  "packageManager": "pnpm@9.12.1",
