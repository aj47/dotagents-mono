{
  "name": "@dotagents/cli",
  "version": "0.0.1",
  "description": "Standalone CLI for DotAgents — terminal user interface built with OpenTUI",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "dotagents": "./dist/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "bun src/index.tsx",
    "start": "bun dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@dotagents/core": "workspace:*",
    "@dotagents/shared": "workspace:*",
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "private": true
}
